####
# Multi-stage build: compile the pls CLI as a GraalVM/Mandrel native
# executable, then run it from a minimal image.
#
#   podman build -t pls-cli -f Containerfile .
#   podman run --rm -it pls-cli <args>
####

# Runtime base image carrying the tools the actions delegate to (aws,
# terraform). make-image.sh builds ../pls-ubi first and overrides this with
# the freshly built tag; standalone builds pull the published base.
ARG BASE_IMAGE=docker.io/prodbytes/pls-ubi:latest

## Stage 1: build the native executable
FROM quay.io/quarkus/ubi10-quarkus-mandrel-builder-image:jdk-25 AS build
USER quarkus
WORKDIR /usr/src/pls

# Resolve dependencies first so this layer is cached across source changes
COPY --chown=quarkus:quarkus mvnw pom.xml ./
COPY --chown=quarkus:quarkus .mvn .mvn
RUN ./mvnw -B quarkus:go-offline

COPY --chown=quarkus:quarkus src src
RUN ./mvnw -B package -Dnative -DskipTests -DskipITs

## Stage 2: run it on the pls-ubi base image (see BASE_IMAGE above)
FROM ${BASE_IMAGE}
WORKDIR /opt/pls
COPY --from=build --chown=1001:root /usr/src/pls/target/pls /opt/pls/pls
USER 1001

ENTRYPOINT ["/opt/pls/pls","gitops"]
